// 1
function exercicio1() {
    let nome = prompt("Digite seu nome:");
    let idade = parseInt(prompt("Digite sua idade:"));
    let altura = parseFloat(prompt("Digite sua altura em metros:"));
    console.log("Olá, meu nome é " + nome + ", tenho " + idade + " anos e minha altura é " + altura + " metros.");
}

// 2
function exercicio2() {
    let idadeAtual = parseInt(prompt("Digite sua idade atual:"));
    console.log("Daqui a 5 anos você terá " + (idadeAtual + 5) + " anos.");
}

// 3
function exercicio3() {
    let reais = parseFloat(prompt("Digite um valor em reais:"));
    let taxaDolar = 5;
    let dolares = reais / taxaDolar;
    console.log("R$ " + reais + " equivalem a US$ " + dolares.toFixed(2) + ".");
}

// 4
function exercicio4() {
    let luzAcesa = false;
    let acao = parseInt(prompt("Digite 1 para acender a luz ou 0 para apagar:"));
    luzAcesa = acao === 1;
    console.log(luzAcesa ? "A luz está acesa" : "A luz está apagada");
}

// 5
function exercicio5() {
    let largura = parseFloat(prompt("Digite a largura do retângulo em metros:"));
    let alturaRet = parseFloat(prompt("Digite a altura do retângulo em metros:"));
    let area = largura * alturaRet;
    console.log("A área do retângulo é " + area + " metros quadrados.");
}

// 6
function exercicio6() {
    let nota1 = parseFloat(prompt("Digite a primeira nota:"));
    let nota2 = parseFloat(prompt("Digite a segunda nota:"));
    let nota3 = parseFloat(prompt("Digite a terceira nota:"));
    let media = (nota1 + nota2 + nota3) / 3;
    console.log("A média das notas é " + media.toFixed(2) + ".");
}

// 7
function exercicio7() {
    let preco = parseFloat(prompt("Digite o preço original do produto:"));
    let desconto = parseFloat(prompt("Digite a porcentagem de desconto:"));
    let precoFinal = preco - (preco * desconto / 100);
    console.log("O valor final com desconto é R$ " + precoFinal.toFixed(2) + ".");
}

// 8
function exercicio8() {
    let celsius = parseFloat(prompt("Digite a temperatura em Celsius:"));
    let fahrenheit = celsius * 9 / 5 + 32;
    console.log(celsius + "°C equivalem a " + fahrenheit.toFixed(2) + "°F.");
}

// 9
function exercicio9() {
    let num1 = parseInt(prompt("Digite o primeiro número inteiro:"));
    let num2 = parseInt(prompt("Digite o segundo número inteiro:"));
    console.log("A soma é " + (num1 + num2));
    console.log("O produto é " + (num1 * num2));
}

// 10
function exercicio10() {
    let valor1 = prompt("Digite o primeiro valor:");
    let valor2 = prompt("Digite o segundo valor:");
    console.log("Antes da troca: valor1 = " + valor1 + ", valor2 = " + valor2);
    let temp = valor1;
    valor1 = valor2;
    valor2 = temp;
    console.log("Depois da troca: valor1 = " + valor1 + ", valor2 = " + valor2);
}
